{{ if eq .chezmoi.osRelease.name "Arch Linux" -}}
#!/bin/sh
sudo localectl set-locale ko_KR.UTF-8
sudo timedatectl set-local-rtc 1 --adjust-system-clock
git clone --depth 1 https://aur.archlinux.org/aura-bin.git
mkdir ~/.local/bin/

git clone --depth 1 https://github.com/xmonad/xmonad-contrib .xmonad/xmonad-contrib
git clone --depth 1 https://github.com/xmonad/xmonad .xmonad/xmonad
git clone --depth 1 https://github.com/kmonad/kmonad .kmonad

curl --proto '=https' --tlsv1.2 -sSf https://get-ghcup.haskell.org | sh

{{ end -}}
