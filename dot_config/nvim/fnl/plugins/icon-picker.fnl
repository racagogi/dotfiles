{1 :ziontee113/icon-picker.nvim
  :dependencies [:stevearc/dressing.nvim]
  :keys [{1 :<M-1>
          2 "<cmd>IconPickerNormal alt_font emoji nerd_font_v3  symbols<CR>"
          :desc "icon picker"
          :mode :n}
         {1 :<M-1>
          2 "<cmd>IconPickerInsert alt_font emoji nerd_font_v3  symbols<CR>"
          :desc "icon picker"
          :mode :i}]
  :opts {:disable_legacy_commands true}}
